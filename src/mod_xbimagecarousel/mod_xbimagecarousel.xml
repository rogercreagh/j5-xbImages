<?xml version="1.0" encoding="UTF-8"?>
<extension type="module" client="site" method="upgrade">
    <name>xbImage Carousel</name>
    <version>0.1.0.0</version>
	<creationDate>15th March 2026</creationDate>
	<author>RogerCO</author>
	<authorEmail>roger@crosborne.co.uk</authorEmail>
	<authorUrl>www.crosborne.uk</authorUrl>
	<copyright>Copyright (C) Roger Creagh-Osborne, 2025, All rights reserved.</copyright>
	<license>GNU/GPL Version 3</license>
	<description>Creates a single image carousel of images sourced from either any /images/ folder or the xbMusic Albums table</description>

	<namespace path="src/">Crosborne\Module\XbimageCarousel</namespace>

	<scriptfile>script.xbimagecarousel.php</scriptfile>	
    <files>
        <folder module="mod_xbimagecarousel">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
        <folder>language</folder>
    </files>
    <media destination="mod_xbimagecarousel" folder="media">
        <filename>joomla.asset.json</filename>
        <folder>css</folder>
        <folder>js</folder>
        <folder>images</folder>
    </media>
    
    <changelogurl>https://raw.githubusercontent.com/rogercreagh/j5-xbImages/main/changelog_xbimagecarousel.xml</changelogurl>
   <!--  http://j5.localhost/updateserver/changelog_xbimagecarousel.xml -->
    <updateservers>
	    <server type="extension" name="xbImageCarousel Module Updates">
	    	https://raw.githubusercontent.com/rogercreagh/j5-xbImages/main/update_xbimagecarousel.xml
	    </server>
	</updateservers>

    <config>
		<inlinehelp button="show"/>
        <fields name="params">
            <fieldset name="basic">
            	<field name="subtitle" type="text"
            		label="MOD_XBIMG_SUBTITLE"
            		description="MOD_XBIMG_SUBTITLE_DESC"
            		hint="optional text above image"
            	/>
            	<field name="img_delay" type="number"
            		label="MOD_XBIMG_DELAY"
            		description="MOD_XBIMG_DELAY_DESC"
            		min="2" max="60" step="1"
            		hint="secs"
            		size="4"
            		default="7"
            	/> 
                <field
                    name="img_source" type="radio"
                    label="MOD_XBIMG_SOURCE"
                    description="MOD_XBIMG_SOURCE_DESC"
 					class="btn-group"
                    default="0"
                    >
						<option value="0">MOD_XBIMG_FOLDER</option>
						<option value="1">MOD_XBIMG_XBMUSIC</option>	
                </field>
                <field name="img_folder" type="folderlist"
			        label="MOD_XBIMG_IMGFOLDER"
			        description="MOD_XBIMG_IMGFOLDER_DESC"
			        directory="images"
			        recursive="true"
			        hide_none="true" hide_default="true"
			        default=""
			        showon="img_source:0"
				/>
				<field name="img_exts" type="text"
					label="MOD_XBIMG_FILETYPES"
					description="MOD_XBIMG_FILETYPE_DESCS"
					default="jpg,jpeg,png"
					showon="img_source:0"
				/>
				<field name="albumsnote" type="note"
					label="MOD_XBIMG_ALBUMNOTE"
					description="MOD_XBIMG_ALBUMNOTE_DESC"
					showon="img_source:1"
				/>
				<field name="albuminfo" type="radio"
					label="MOD_XBIMG_ALBUMINFO"
					description="MOD_XBIMG_ALBUMINFO_DESC"
 					class="btn-group btn-group-yesno"
					default="0"
					showon="img_source:1"
				>
					<option value="0">MOD_XBIMG_NONE</option>
					<option value="1">MOD_XBIMG_TITLE</option>
					<option value="2">MOD_XBIMG_ARTIST</option>
					<option value="3">MOD_XBIMG_BOTH</option>
				</field>
				<field name="showyear" type="radio"
					label="MOD_XBIMG_SHOWYEAR"
					description="MOD_XBIMG_SHOWYEAR_DESC"
		 			class="btn-group btn-group-yesno"
					default="0"
					showon="albuminfo:1[OR]albuminfo:3"
				>
					<option value="0">MOD_XBIMG_HIDE</option>
					<option value="1">MOD_XBIMG_SHOW</option>
				</field>
				<field name="albumtags" type="tag"
					label="MOD_XBIMG_TAGS"
					description="MOD_XBIMG_TAGS_DESC"
					mode="nested"
					multiple="true"
					showon="img_source:1"
				/>
			
            </fieldset>
        </fields>
    </config>
</extension>